# === Obrigatórias (Coolify ou .env local) ===
POSTGRES_PASSWORD=
AUTH_JWT_SECRET=

# === Banco de dados ===
POSTGRES_DB=erp_vendas
POSTGRES_USER=postgres

# === VeloFlow ERP ===
ACTIVE_ERP=veloflow
VELOFLOW_API_URL=https://api.veloflow.com.br/api/v1
VELOFLOW_API_TOKEN=
VELOFLOW_TIMEOUT=30
VELOFLOW_RETRY_ATTEMPTS=3
VELOFLOW_VERIFY_SSL=False

# === Sync ===
SYNC_INTERVAL_MINUTES=30
SYNC_FULL_HOUR=3

# === Frontend (build-time, apenas se chamar backend diretamente) ===
# VITE_BACKEND_URL=  # Deixar vazio = usa nginx proxy (mesmo domínio)
